# Aplicación
APP_NAME="Finanzas Personales"
APP_VERSION="1.0.0"
DEBUG=true

# Base de datos
DATABASE_URL="sqlite:///./finanzas.db"
SEED_ON_STARTUP=false

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:3000", "http://127.0.0.1:3000", "http://localhost:8081", "http://127.0.0.1:8081", "http://localhost:8082", "http://127.0.0.1:8082"]

# Autenticación
# Cambia esta clave antes de exponer la API fuera de tu máquina.
SECRET_KEY="cambia-esta-clave-en-produccion"
ACCESS_TOKEN_EXPIRE_SECONDS=2592000
DEFAULT_LOCAL_USER_EMAIL="local@finanzas.app"
DEFAULT_LOCAL_USER_PASSWORD="local-dev-password"

# Scraping bancario
# Clave de cifrado para las credenciales de banco guardadas en la BD local.
# Genérala con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SCRAPER_ENCRYPTION_KEY=
# false = navegador visible. Recomendado para bancos con Cloudflare (BCI): en
# headless el desafío anti-bot casi nunca pasa.
SCRAPER_HEADLESS=false
SCRAPER_BROWSER_CHANNEL=chrome
SCRAPER_DEBUG_DIR=data/scraper_debug
SCRAPER_PROFILES_DIR=data/browser_profiles
# Segundos a esperar a que el desafío de Cloudflare se resuelva (auto o a mano).
SCRAPER_CHALLENGE_WAIT_SECONDS=120
# Habilita el "Banco de Prueba" (FakeScraper) para validar el flujo sin un banco real.
SCRAPER_FAKE=false

# Sincronización automática en segundo plano.
# Con navegador visible conviene dejarla en false y sincronizar manualmente
# desde la UI (si no, abriría ventanas del navegador solas).
BANK_AUTO_SYNC_ENABLED=false
BANK_AUTO_SYNC_INTERVAL_SECONDS=21600
BANK_SYNC_STAGGER_SECONDS=45
