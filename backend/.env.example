# Aplicación
APP_NAME="Finanzas Personales"
APP_VERSION="1.0.0"
DEBUG=true

# Base de datos
DATABASE_URL="sqlite:///./finanzas.db"
SEED_ON_STARTUP=false

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# LLM / IA
# Opciones: mock | openai | ollama
LLM_PROVIDER=mock
OPENAI_API_KEY=
MODEL_NAME=gpt-4.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Fintoc (proveedor bancario)
FINTOC_SECRET_KEY=
FINTOC_BASE_URL=https://api.fintoc.com/v1
FINTOC_WEBHOOK_SECRET=
FINTOC_WEBHOOK_STRICT_SIGNATURE=true
